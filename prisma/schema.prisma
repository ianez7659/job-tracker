generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  createdAt     DateTime  @default(now())
  password      String?
  image         String?
  emailVerified DateTime?
  category      String?
  accounts      Account[]
  jobs          Job[]
  sessions      Session[]

  @@map("User")
}

model Job {
  id         String    @id @default(cuid())
  title      String
  company    String
  status     String
  appliedAt  DateTime
  tags       String?
  userId     String
  createdAt  DateTime  @default(now())
  deletedAt  DateTime?
  url        String?
  jd         String?
  resumeFile String?
  user       User      @relation(fields: [userId], references: [id])
  atsMatchSnapshots AtsMatchSnapshot[]
}

/// ATS-style match runs for Applying (history, deltas, future subscores/actions).
model AtsMatchSnapshot {
  id        String   @id @default(cuid())
  jobId     String
  createdAt DateTime @default(now())
  payload   Json

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, createdAt])
  @@map("AtsMatchSnapshot")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id])

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
