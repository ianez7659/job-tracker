generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String            @id @default(cuid())
  email         String            @unique
  name          String?
  createdAt     DateTime          @default(now())
  password      String?
  image         String?
  emailVerified DateTime?
  category      String?
  hubStatus     HubProfileStatus?
  headline      String?           @db.VarChar(500)
  accounts      Account[]
  jobs          Job[]
  sessions      Session[]
  xp            UserXp?
  quizSessions  DailyQuizSession[]

  @@map("User")
}

enum HubProfileStatus {
  STUDENT
  ALUMNI
  STAFF
}

/// How this job row was created (extend with new Prisma enum values + migration when needed).
enum JobSource {
  ONLINE
  WALK_IN
}

model Job {
  id            String    @id @default(cuid())
  title         String
  company       String
  status        String
  appliedAt     DateTime
  tags          String?
  source        JobSource @default(ONLINE)
  userId        String
  createdAt     DateTime  @default(now())
  deletedAt     DateTime?
  url           String?
  jd            String?
  resumeFile    String?
  cycleEndStage String?   // last non-terminal stage when job reached offer/rejected
  user          User      @relation(fields: [userId], references: [id])
  atsMatchSnapshots AtsMatchSnapshot[]
}

/// ATS-style match runs for Applying (history, deltas, future subscores/actions).
model AtsMatchSnapshot {
  id        String   @id @default(cuid())
  jobId     String
  createdAt DateTime @default(now())
  payload   Json

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, createdAt])
  @@map("AtsMatchSnapshot")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id])

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── XP System ────────────────────────────────────────────────────────────────

enum XpReason {
  DAILY_ACTIVITY       // +8 XP once per day when meaningful action taken
  JOB_CREATED          // +10 XP on job card creation
  JOB_CREATED_COMPLETE // +5 XP bonus when card has all core fields filled
  CYCLE_COMPLETED      // +30 XP when job reaches offer or rejected
  CYCLE_INTERVIEW_BONUS // +10 XP when cycle passed at least one interview stage
  CYCLE_NOTE_BONUS     // +5 XP when job has a final note/jd on cycle close
  WEEKLY_REVIEW        // +20 XP when weekly review requirement is completed
}

/// One row per user — aggregate XP state.
model UserXp {
  id                  String    @id @default(cuid())
  userId              String    @unique
  totalXp             Int       @default(0)
  currentLevel        Int       @default(1)
  lastDailyAt         DateTime? // last DAILY_ACTIVITY award instant (audit)
  dailyTimeZone       String? // IANA TZ from client (e.g. America/Vancouver)
  lastDailyPeriodKey  String? // YYYY-MM-DD of "day" starting at local anchor hour (see lib/xp/dailyPeriod)
  user                User      @relation(fields: [userId], references: [id])
  events              XpEvent[]

  @@map("UserXp")
}

/// Append-only log of every XP grant.
model XpEvent {
  id        String    @id @default(cuid())
  userXpId  String
  reason    XpReason
  amount    Int
  jobId     String?   // which job triggered the event (nullable for daily/weekly)
  createdAt DateTime  @default(now())
  userXp    UserXp    @relation(fields: [userXpId], references: [id])

  @@index([userXpId, createdAt])
  @@map("XpEvent")
}

// ── Daily Interview Quiz ──────────────────────────────────────────────────────

/// Question bank: one row per source question imported from data/quiz/*.json.
/// Content is treated as reviewed source data and must not be auto-generated.
model QuizQuestion {
  id                 String   @id @default(cuid())
  /// Original question id from the JSON file (e.g. "web-dev-html-semantic-001").
  sourceId           String   @unique
  /// "common" | "group_common" | "category_specific" | "ai_card_based"
  sourceType         String
  /// Quiz JSON categoryGroup (e.g. "Tech", "Management", "Marketing", "Common")
  categoryGroup      String
  /// Quiz JSON category in hyphen format (e.g. "web-development")
  category           String
  /// "behavioral" | "situational" | "role_specific" | "interview_basics"
  questionType       String
  /// "easy" | "medium" | "hard"
  difficulty         String
  question           String
  /// [{id: string, text: string}, ...]
  choices            Json
  correctChoiceId    String
  correctExplanation String
  /// [{choiceId: string, explanation: string}, ...]
  wrongExplanations  Json
  /// string[]
  tags               Json
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  sessionItems DailyQuizSessionItem[]

  @@index([category, difficulty])
  @@index([categoryGroup])
  @@map("QuizQuestion")
}

/// One quiz session per user per day per category.
/// Stores the user's progress through 5 daily interview questions.
model DailyQuizSession {
  id                 String    @id @default(cuid())
  userId             String
  /// YYYY-MM-DD in the user's local timezone
  dateKey            String
  /// USER_CATEGORIES value in underscore format (e.g. "web_development")
  category           String
  /// PARENT_CATEGORIES id in lowercase (e.g. "tech")
  categoryGroup      String
  /// "not_started" | "in_progress" | "completed"
  status             String    @default("not_started")
  totalQuestions     Int       @default(5)
  completedQuestions Int       @default(0)
  createdAt          DateTime  @default(now())
  completedAt        DateTime?

  user  User                   @relation(fields: [userId], references: [id])
  items DailyQuizSessionItem[]

  /// One session per user per day per category
  @@unique([userId, dateKey, category])
  @@index([userId, dateKey])
  @@map("DailyQuizSession")
}

/// One row per question within a DailyQuizSession.
/// All question/choices/explanation content is snapshotted at session creation
/// so the session is stable even if the source question is later edited.
model DailyQuizSessionItem {
  id        String @id @default(cuid())
  sessionId String
  /// Nullable: AI-generated questions have no QuizQuestion row
  questionId String?
  /// "common" | "group_common" | "category_specific" | "ai_card_based"
  sourceType String
  /// 0-based position in the session (0–4 for a 5-question session)
  orderIndex Int

  // ── Question snapshot (immutable after creation) ──────────────────────
  renderedQuestionSnapshot   String
  /// [{id, text}, ...] in shuffled order as shown to the user
  choicesSnapshot            Json
  /// Correct choice id from the original question
  correctChoiceIdSnapshot    String
  /// Index of the correct choice in choicesSnapshot (0-based)
  correctIndexSnapshot       Int
  correctExplanationSnapshot String
  /// [{choiceId, explanation}, ...]
  wrongExplanationsSnapshot  Json

  // ── User answer (nullable until answered) ─────────────────────────────
  userAnswerChoiceId String?
  userAnswerIndex    Int?
  isCorrect          Boolean?
  answeredAt         DateTime?

  /// Extensible metadata (e.g. AI generation params, score adjustments)
  metadata Json?

  session  DailyQuizSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  question QuizQuestion?    @relation(fields: [questionId], references: [id])

  @@index([sessionId, orderIndex])
  @@map("DailyQuizSessionItem")
}
