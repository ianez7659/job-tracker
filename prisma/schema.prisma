generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String            @id @default(cuid())
  email         String            @unique
  name          String?
  createdAt     DateTime          @default(now())
  password      String?
  image         String?
  emailVerified DateTime?
  category      String?
  hubStatus     HubProfileStatus?
  headline      String?           @db.VarChar(500)
  accounts      Account[]
  jobs          Job[]
  sessions      Session[]
  xp            UserXp?

  @@map("User")
}

enum HubProfileStatus {
  STUDENT
  ALUMNI
  STAFF
}

/// How this job row was created (extend with new Prisma enum values + migration when needed).
enum JobSource {
  ONLINE
  WALK_IN
}

model Job {
  id            String    @id @default(cuid())
  title         String
  company       String
  status        String
  appliedAt     DateTime
  tags          String?
  source        JobSource @default(ONLINE)
  userId        String
  createdAt     DateTime  @default(now())
  deletedAt     DateTime?
  url           String?
  jd            String?
  resumeFile    String?
  cycleEndStage String?   // last non-terminal stage when job reached offer/rejected
  user          User      @relation(fields: [userId], references: [id])
  atsMatchSnapshots AtsMatchSnapshot[]
}

/// ATS-style match runs for Applying (history, deltas, future subscores/actions).
model AtsMatchSnapshot {
  id        String   @id @default(cuid())
  jobId     String
  createdAt DateTime @default(now())
  payload   Json

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, createdAt])
  @@map("AtsMatchSnapshot")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id])

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── XP System ────────────────────────────────────────────────────────────────

enum XpReason {
  DAILY_ACTIVITY       // +8 XP once per day when meaningful action taken
  JOB_CREATED          // +10 XP on job card creation
  JOB_CREATED_COMPLETE // +5 XP bonus when card has all core fields filled
  CYCLE_COMPLETED      // +30 XP when job reaches offer or rejected
  CYCLE_INTERVIEW_BONUS // +10 XP when cycle passed at least one interview stage
  CYCLE_NOTE_BONUS     // +5 XP when job has a final note/jd on cycle close
  WEEKLY_REVIEW        // +20 XP when weekly review requirement is completed
}

/// One row per user — aggregate XP state.
model UserXp {
  id                  String    @id @default(cuid())
  userId              String    @unique
  totalXp             Int       @default(0)
  currentLevel        Int       @default(1)
  lastDailyAt         DateTime? // last DAILY_ACTIVITY award instant (audit)
  dailyTimeZone       String? // IANA TZ from client (e.g. America/Vancouver)
  lastDailyPeriodKey  String? // YYYY-MM-DD of "day" starting at local anchor hour (see lib/xp/dailyPeriod)
  user                User      @relation(fields: [userId], references: [id])
  events              XpEvent[]

  @@map("UserXp")
}

/// Append-only log of every XP grant.
model XpEvent {
  id        String    @id @default(cuid())
  userXpId  String
  reason    XpReason
  amount    Int
  jobId     String?   // which job triggered the event (nullable for daily/weekly)
  createdAt DateTime  @default(now())
  userXp    UserXp    @relation(fields: [userXpId], references: [id])

  @@index([userXpId, createdAt])
  @@map("XpEvent")
}
